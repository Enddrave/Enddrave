<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bhupendra Kumar Gupta | Digital Business Card</title>
  <style>
    body {
      font-family: "Poppins", sans-serif;
      background: linear-gradient(135deg, #f5f7fa, #d4e8d4);
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .card {
      background: #ffffff;
      max-width: 420px;
      width: 90%;
      border-radius: 28px;
      overflow: hidden;
      border: none;
      box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.5), 0 18px 48px rgba(0, 0, 0, 0.22);
    }

    .header {
      background: linear-gradient(135deg, #004d26, #00b359);
      color: #ffffff;
      padding: 30px;
      text-align: center;
      border-bottom: 4px solid #ffd700;
    }

    .name {
      font-size: 24px;
      margin: 5px 0 2px;
      font-weight: 700;
      color: #ffffff;
      letter-spacing: 1px;
    }

    .title {
      font-size: 14px;
      font-weight: 500;
      color: #ffd700;
      letter-spacing: 1.5px;
    }

    .photo {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      margin-top: -50px;
      border: 5px solid #ffffff;
      box-shadow: 0 0 15px rgba(0, 128, 0, 0.5);
    }

    .content {
      padding: 25px;
      text-align: center;
      background: linear-gradient(135deg, #ffffff, #e6f5e6);
    }

    .content p {
      margin: 6px 0;
      font-size: 13px;
      color: #333;
      font-weight: 500;
    }

    footer {
      font-size: 14px;
      color: #004d26;
      margin: 20px 0;
      font-style: italic;
      text-align: center;
      font-weight: 600;
      letter-spacing: 0.8px;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <div class="name">Bhupendra Kumar Gupta</div>
      <div class="title">DIRECTOR</div>
    </div>

    <div class="content">
      <div style="text-align: center;">
        <img
          src="https://raw.githubusercontent.com/Enddrave/Enddrave/main/logo/Enddrave_TM.png"
          alt="Company Logo"
          class="photo"
          style="margin: auto; width: 180px; height: 180px;"
        />
      </div>

      <p
        style="
          font-size: clamp(12px, 4vw, 18px);
          font-weight: 600;
          color: #006400;
          text-align: center;
          line-height: 1.3;
          font-family: 'Poppins', sans-serif;
          white-space: nowrap;
        "
      >
        <strong>Enddrave Tech Innovation Private Limited</strong>
      </p>

      <p>📍 Chhatarpur, Madhya Pradesh, India – 471001</p>

      <p>📞 Mobile: +91 91712 36317</p>
      <p>✉️ Email: admin@enddrave.com</p>
      <p>💬 WhatsApp: +91 91712 36317</p>
      <p>🌐 Website: https://www.enddrave.com</p>
      <p>🔗 LinkedIn: Enddrave Tech Innovation Pvt. Ltd.</p>

      <div style="margin-top: 18px; text-align: center;">
        <img
          src="https://api.qrserver.com/v1/create-qr-code/?data=https://www.enddrave.com&size=140x140"
          alt="QR Code"
          style="
            border: none;
            border-radius: 16px;
            padding: 6px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2),
              0 0 15px rgba(255, 215, 0, 0.5);
          "
        />
      </div>

      <footer style="margin-top: 14px;">
        “Innovating IoT, Embedded & Smart Solutions”<br />
        <span style="color: #00a86b; font-weight: 700;"
          >🌟 Elevating the Future with Enddrave 🌟</span
        >
      </footer>
    </div>
  </div>
</body>
</html>
